# Haven — Firebase web config
# 1. Firebase console → Project settings → "Your apps" → Web app → Config
# 2. Copy each value into a file named ".env" (same folder as this file).
# 3. Restart `npm run dev` after changing these.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=353887280737
VITE_FIREBASE_APP_ID=your-app-id
